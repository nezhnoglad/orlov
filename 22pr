#include <iostream>
#include <string>

using namespace std;

int main() {
    setlocale(0, "");
    int arrInt[10] = { 1, 20, 32, 4, 1, 2, 2, 54, 23, 0 };
    short arrShort[10] = { 10, -5, 100, -200, 50, 75, -30, 88, 15, -10 };
    long arrLong[10] = { 1000L, 2000L, -3000L, 4000L, 5000L, -6000L, 7000L, 8000L, 9000L, 10000L };
    float arrFloat[10] = { 1.1f, 2.2f, 3.3f, 4.4f, 5.5f, 6.6f, 7.7f, 8.8f, 9.9f, 10.0f };
    double arrDouble[10] = { 0.123, 1.234, 2.345, 3.456, 4.567, 5.678, 6.789, 7.890, 8.901, 9.012 };
    char arrChar[10] = { 'A', 'B', 'C', 'D', 'E', 'F', 'G', 'H', 'I', 'J' };
    bool arrBool[10] = { true, false, true, true, false, false, true, false, true, false };
    string arrString[10] = { "Hello", "World", "C++", "Array", "Test", "Data", "Value", "Code", "Output", "Example" };

    
    cout << "[ + ] Массив INT:" << endl;
    for (int i = 0; i < 10; i++) {
        cout << "[ + ] arrInt [" << i << "]\t| значение: " << arrInt[i] << endl;
    }

    
    cout << "[ + ] Массив SHORT:" << endl;
    for (int i = 0; i < 10; i++) {
        cout << "[ + ] arrShort [" << i << "]\t| значение: " << arrShort[i] << endl;
    }

    
    cout << "[ + ] Массив LONG:" << endl;
    for (int i = 0; i < 10; i++) {
        cout << "[ + ] arrLong [" << i << "]\t| значение: " << arrLong[i] << endl;
    }

    
    cout << "[ + ] Массив FLOAT:" << endl;
    for (int i = 0; i < 10; i++) {
        cout << "[ + ] arrFloat [" << i << "]\t| значение: " << arrFloat[i] << endl;
    }

    
    cout << "[ + ] Массив DOUBLE:" << endl;
    for (int i = 0; i < 10; i++) {
        cout << "[ + ] arrDouble [" << i << "]\t| значение: " << arrDouble[i] << endl;
    }

    
    cout << "[ + ] Массив CHAR:" << endl;
    for (int i = 0; i < 10; i++) {
        cout << "[ + ] arrChar [" << i << "]\t| значение: " << arrChar[i] << endl;
    }

    
    cout << "[ + ] Массив BOOL:" << endl;
    for (int i = 0; i < 10; i++) {
        cout << "[ + ] arrBool [" << i << "]\t| значение: " << (arrBool[i] ? "true" : "false") << endl;
    }

    
    cout << "[ + ] Массив STRING:" << endl;
    for (int i = 0; i < 10; i++) {
        cout << "[ + ] arrString [" << i << "]\t| значение: " << arrString[i] << endl;
    }

    return 0;
}
